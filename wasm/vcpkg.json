    },
    "sqlite3",
    "yaml-cpp",
    {
      "name": "libzip",
      "default-features": false,
      "features": [
        "bzip2"
      ]
    },
    "marisa-trie",
    {
      "name": "sdl3-image",
      "features": [
        "png",
        "webp"
      ]
    },
    {
      "name": "sdl3-ttf",
      "features": [
        "svg"
      ]
    },
    {
      "name": "sdl3-mixer",
      "features": [
        "fluidsynth"
      ]
    }
  ]
}
